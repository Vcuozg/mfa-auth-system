# Sao chép file này thành .env.local và điền giá trị

DATABASE_URL="file:./dev.db"

# Tạo bằng lệnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-byte-hex-string"

# Tạo bằng lệnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY="replace-with-32-byte-hex-string-64-chars"
